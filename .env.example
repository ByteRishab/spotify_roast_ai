# Spotify — get from https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIPY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REDIRECT_URI=http://localhost:5000/callback

# Google Gemini — get from https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key

# Flask session encryption key — make this a long random string
FLASK_SECRET_KEY=change-this-to-something-random-and-long
